{
  "name": "github-desktop-next",
  "version": "0.1.0",
  "private": true,
  "description": "Next-generation GitHub Desktop (community fork) — Tauri + Vite + Rust migration workspace",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --filter @github-desktop-next/app dev",
    "build": "pnpm --filter @github-desktop-next/app build",
    "tauri": "pnpm --filter @github-desktop-next/app tauri",
    "tauri:dev": "pnpm --filter @github-desktop-next/app tauri dev",
    "tauri:build": "pnpm --filter @github-desktop-next/app tauri build",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,yaml,yml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,yaml,yml,md}\""
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "vite": "^8.0.16"
  }
}
