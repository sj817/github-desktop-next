auto-install-peers=true
strict-peer-dependencies=false
# Flat node_modules (npm/yarn-style). The ported official/ renderer imports many
# transitive packages directly (semver, focus-trap, winston-transport, …) and its
# Primer SCSS uses `~pkg` imports that expect a hoisted layout. node-linker=hoisted
# reproduces the flat tree the legacy `app/node_modules` junction used to provide.
node-linker=hoisted
